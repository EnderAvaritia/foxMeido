# ── foxMeido 配置模板 ─────────────────────────────────────────
# 复制为 .env 并按需修改。.env 已在 .gitignore 中，不会泄露到仓库。
#
# 首次配置：
#   1. 复制此文件为 .env
#   2. 填写 QQ 机器人的 bot 信息
#   3. 如果使用 NocoDB，填写 NOCO_TOKEN 和表格 ID
#   4. 如果使用 Steam 相关功能（wish、steamGoods 等），配置代理和 Cookie
#
# 错误日志自动写入项目根目录 logs/error.log，无需额外配置。

# ── 运行环境 ─────────────────────────────────────────────────
ENVIRONMENT=dev
DRIVER=~httpx+~websockets
COMMAND_START=["#"]
# 如果不想用指令前缀（直接发 id xxx），设为空数组：
# COMMAND_START=[""]
QQ_IS_SANDBOX=true

# ── 运行服务（可选）───────────────────────────────────────────
# 监听地址和端口，某些适配器（如 OneBot）需要
# HOST=127.0.0.1
# PORT=26657

# ── QQ 机器人 ─────────────────────────────────────────────────
# 在 https://q.qq.com/ 创建应用后获取 bot 信息
QQ_BOTS='
[
    {
        "id":"你的BOT_APP_ID",
        "token":"你的BOT_TOKEN",
        "secret":"你的BOT_SECRET",
        "intent":{
            "c2c_group_at_messages":true
        }
    }
]'

# ── OneBot V11（可选）─────────────────────────────────────────
# 配合 OneBot 协议端（如 go-cqhttp、Lagrange）使用
# ONEBOT_API_ROOTS={"机器人QQ": "http://127.0.0.1:26657/"}
# ONEBOT_WS_URLS=["ws://192.168.10.14:26657"]

# ── NocoDB（可选）─────────────────────────────────────────────
# 部署详见：https://github.com/nocodb/nocodb
# NOCO_URL=https://127.0.0.1:52533/api/v2/tables
# NOCO_TOKEN=your_nocodb_token_here
# NOCO_ACCOUNT_TABLE=mtab_xxxxx
# NOCO_RECORD_TABLE=mtab_xxxxx
# NOCO_REMAIN_TABLE=mtab_xxxxx
# NOCO_WISHLIST_TABLE=mtab_xxxxx
#
# 国内自建 NocoDB 通常使用自签名证书，默认不验证 SSL。
# 如需验证设为 true：
# NOCO_VERIFY_SSL=false

# ── 代理（可选，默认不启用）───────────────────────────────────
# 国内访问 Steam / iflow 等网站需要代理转发时，取消注释并设置。
# 只需设置 HTTP_PROXY，HTTPS_PROXY 会自动跟随。
# 不设置 = 不使用代理。
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ── Steam（可选）───────────────────────────────────────────────
# 商店页面 Cookie，用于 wish 等需要登录 store.steampowered.com 的功能
# STEAM_COOKIE=your_steam_store_cookie
# CURATOR_ID=0

# ── 鉴赏家副本监控（可选）─────────────────────────────────────────
# 监控 Steam 鉴赏家待处理游戏副本，有新邀请时通过 QQ 群 / ntfy 推送。
# 注意：鉴赏家后台 Cookie 与商店页面 Cookie 不同，需单独配置。
# CURATOR_COOKIE=your_curator_admin_cookie   # 鉴赏家后台 Cookie（从 curator/admin 页面获取）
# CURATOR_ENABLED=true                        # 是否启用每日定时检查
# CURATOR_NAME=鉴赏家名                       # 鉴赏家显示名称
# CURATOR_NOTIFY_GROUP=群号                   # 每日定时推送的目标群号
# CURATOR_CHECK_TIME=09:00                    # 每日检查时间（默认 09:00）
# CURATOR_NTFY_TOPIC=your_ntfy_topic          # 可选，设了则额外推送到 ntfy

# ── 消息表情回复（可选）─────────────────────────────────────────
# 收到消息后立即添加表情回复（如 ✅），类似 QQ 群聊的"表情回应"。
# 仅当协议端（如 NapCat/OneBot V11）支持时生效，不支持时自动忽略。
# 启用后默认在处理结束后撤回表情，设为 false 可保留。
# MESSAGE_REACTION_ENABLED=false
# MESSAGE_REACTION_FACE_ID=32       # QQ 表情 ID：32=✅, 212=🤔, 26=❌, 351=👍
# MESSAGE_REACTION_AUTO_REMOVE=true # 处理结束后自动撤回表情
